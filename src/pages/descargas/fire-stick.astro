---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../config/site';

const title = 'Guia Fire Stick | Flujo TV Mexico';
const description = 'Guia de instalacion Flujo TV Mexico para Fire Stick con checklist y preguntas frecuentes.';

const steps = [
  'Instala Downloader en tu Fire Stick desde la tienda.',
  'Activa apps externas para Downloader en configuracion.',
  `Ingresa el codigo ${site.downloaderCode} para descargar la app oficial.`,
  'Completa instalacion y abre Flujo TV desde aplicaciones.',
  'Inicia sesion y valida reproduccion estable.'
];

const faqItems = [
  { q: 'Es compatible con Fire Stick?', a: 'Si, funciona en modelos compatibles que permiten instalar Downloader.' },
  { q: 'Necesito navegador?', a: 'No. Todo el proceso se realiza desde Downloader y ajustes del sistema.' },
  { q: 'Puedo recibir soporte en la instalacion?', a: 'Si, soporte por WhatsApp acompana el proceso completo.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <Navigation />

  <main class="py-16 md:py-24">
    <section class="container-main grid gap-6 lg:grid-cols-[1fr_320px]">
      <article class="surface-panel p-6 md:p-8">
        <a href="/descargas/" class="text-sm font-semibold text-rose-300 hover:text-white">← Volver al centro de guias</a>
        <h1 class="mt-4 font-display text-4xl font-bold text-white">Guia Fire Stick</h1>
        <p class="mt-3 text-zinc-100/90">Instalacion segura en Fire Stick con pasos concretos y validacion final.</p>

        <div class="mt-5 rounded-xl border border-white/15 bg-white/10 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-rose-300">Codigo Downloader</p>
          <p class="mt-1 font-display text-3xl font-bold text-white">{site.downloaderCode}</p>
        </div>

        <div class="mt-6 space-y-3">
          {steps.map((step, index) => (
            <div class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 p-4">
              <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full bg-rose-500/20 text-xs font-bold text-rose-200">{index + 1}</span>
              <p class="text-zinc-100">{step}</p>
            </div>
          ))}
        </div>
      </article>

      <aside class="card-dark h-fit p-5 lg:sticky lg:top-24">
        <p class="text-xs uppercase tracking-[0.2em] text-rose-300">Soporte</p>
        <h2 class="mt-2 font-display text-2xl font-bold text-white">Soporte de instalacion</h2>
        <p class="mt-2 text-sm text-zinc-200/90">Te guiamos en configuracion y activacion final por WhatsApp.</p>
        <a href={`${site.whatsappLink}?text=${encodeURIComponent('Hola, necesito ayuda con la guia Fire Stick de Flujo TV Mexico.')}`} target="_blank" rel="noopener noreferrer" class="mt-5 block rounded-full bg-rose-600 px-4 py-3 text-center text-sm font-bold text-white hover:bg-rose-500">Soporte por WhatsApp</a>
      </aside>
    </section>
  </main>

  <Footer />
</Layout>
