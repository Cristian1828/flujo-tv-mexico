---
import Layout from '../layouts/Layout.astro';
import { plans } from '../config/site';

const BRAND   = 'netvantage';
const COUNTRY = 'MX';
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'https://api.optimait.site';

const PLAN_MONTHS_MAP: Record<string, number> = {
  'mensual': 1, 'trimestral': 3, 'semestral': 7, 'anual': 14,
};

const PLANS_DATA = plans.map(p => ({
  id: p.id, name: p.name, price: p.price, bonus: p.bonus || null,
}));
const defaultPlan = plans[0]!;
---

<Layout
  title="Activar plan · Flujo TV México"
  description="Activa tu membresía en Flujo TV México. Streaming premium sin contratos."
  noIndex={true}
>
  <main class="mx-page">

    <!-- Fondo con orbes de luz -->
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="orb orb-3" aria-hidden="true"></div>

    <div class="mx-wrap">

      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Volver al inicio
      </a>

      <!-- Header con logo centrado -->
      <header class="mx-header">
        <div class="logo-ring">
          <img src="/images/logo_flujo.webp" alt="Flujo TV México" class="mx-logo" />
        </div>
        <div>
          <h1 class="mx-brand">Flujo <span class="brand-accent">TV</span></h1>
          <p class="mx-tagline">🇲🇽 México · Activación inmediata</p>
        </div>
      </header>

      <!-- Plan card — glass con precio destacado -->
      <div class="plan-glass">
        <div class="plan-glow" aria-hidden="true"></div>
        <div class="plan-inner">
          <div class="plan-top">
            <span class="plan-badge">✦ Plan Seleccionado</span>
            <p class="plan-name" id="plan-name">{defaultPlan.name}</p>
            <p class="plan-bonus" id="plan-bonus" style="display:none"></p>
          </div>
          <div class="plan-bottom">
            <p class="plan-price" id="plan-price">${defaultPlan.price}</p>
            <div class="plan-meta">
              <span class="plan-currency">USD</span>
              <span class="plan-per" id="plan-per" style="display:none"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulario glass -->
      <div class="form-glass">
        <p class="form-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Tus datos de activación
        </p>

        <form id="checkout-form" novalidate>

          <div class="field">
            <label for="f-name">Nombre Completo <span class="req">*</span></label>
            <input id="f-name" type="text" placeholder="Carlos Hernández" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="f-email">Correo Electrónico <span class="req">*</span></label>
            <input id="f-email" type="email" placeholder="carlos@correo.com" autocomplete="email" required />
            <p class="field-hint" id="email-hint"></p>
          </div>

          <div class="field">
            <label for="f-phone">Número de Celular <span class="req">*</span></label>
            <input id="f-phone" type="tel" autocomplete="tel" required />
          </div>

          <div class="field">
            <label for="f-user">
              Nombre de Usuario <span class="opt">(opcional)</span>
              <span class="hint-inline">solo letras, números y puntos</span>
            </label>
            <input id="f-user" type="text" placeholder="Se generará automáticamente" autocomplete="off" />
            <p class="field-hint" id="user-hint"></p>
          </div>

          <div class="error-box" id="form-error" style="display:none"></div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span id="btn-text">Continuar al pago →</span>
          </button>

        </form>
      </div>

      <p class="footer-note">Tu acceso a Flujo TV se te enviará por tu número de WhatsApp y correo electrónico.</p>

    </div>
  </main>
</Layout>

<style>
  .mx-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem 4rem;
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse 120% 80% at 50% -10%, #2d0a18 0%, #0f0a14 45%, #07050d 100%);
  }

  /* Orbes de luz flotantes */
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(225,29,72,.18) 0%, transparent 70%);
    top: -150px; left: -150px;
  }
  .orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(159,18,57,.12) 0%, transparent 70%);
    bottom: -100px; right: -100px;
  }
  .orb-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(225,29,72,.08) 0%, transparent 70%);
    top: 40%; left: 50%;
    transform: translateX(-50%);
  }

  .mx-wrap {
    width: 100%;
    max-width: 480px;
    position: relative;
    z-index: 1;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .78rem;
    color: rgba(255,255,255,.3);
    margin-bottom: 1.75rem;
    transition: color .2s;
    font-family: 'Figtree', sans-serif;
    letter-spacing: .01em;
  }
  .back-link:hover { color: rgba(255,255,255,.7); }

  /* ── Header ── */
  .mx-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .logo-ring {
    width: 56px; height: 56px;
    border-radius: 16px;
    padding: 2px;
    background: linear-gradient(135deg, rgba(225,29,72,.6), rgba(159,18,57,.3));
    flex-shrink: 0;
  }
  .mx-logo {
    width: 100%; height: 100%;
    border-radius: 14px;
    object-fit: contain;
    background: #0f0a14;
    padding: 4px;
  }
  .mx-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: -.01em;
  }
  .brand-accent {
    background: linear-gradient(135deg, #e11d48, #fb7185);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .mx-tagline {
    font-size: .75rem;
    color: rgba(255,255,255,.45);
    margin-top: .3rem;
    font-family: 'Figtree', sans-serif;
  }

  /* ── Plan glass card ── */
  .plan-glass {
    position: relative;
    border-radius: 20px;
    margin-bottom: 1.25rem;
    padding: 1px;
    background: linear-gradient(135deg, rgba(225,29,72,.4), rgba(255,255,255,.06), rgba(225,29,72,.15));
  }
  .plan-glow {
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(225,29,72,.2), transparent 70%);
    pointer-events: none;
  }
  .plan-inner {
    background: rgba(20,8,16,.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 19px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .plan-badge {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fb7185;
    display: block;
    margin-bottom: .4rem;
    font-family: 'Figtree', sans-serif;
  }
  .plan-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
  }
  .plan-bonus {
    font-size: .72rem;
    color: #fb7185;
    margin-top: .3rem;
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
  }
  .plan-bottom {
    text-align: right;
    flex-shrink: 0;
  }
  .plan-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, #fff 30%, #fb7185);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .plan-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: .4rem;
    margin-top: .25rem;
  }
  .plan-currency {
    font-size: .7rem;
    font-weight: 700;
    color: rgba(255,255,255,.4);
    font-family: 'Figtree', sans-serif;
  }
  .plan-per {
    font-size: .7rem;
    color: rgba(255,255,255,.3);
    font-family: 'Figtree', sans-serif;
  }

  /* ── Form glass card ── */
  .form-glass {
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 8px 40px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.06);
  }

  .form-title {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.3);
    margin-bottom: 1.35rem;
    font-family: 'Figtree', sans-serif;
  }

  .field { margin-bottom: 1.1rem; }

  .field label {
    display: block;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.6);
    margin-bottom: .4rem;
    font-family: 'Figtree', sans-serif;
  }
  .req { color: #e11d48; margin-left: .1rem; }
  .opt { font-weight: 400; color: rgba(255,255,255,.25); font-size: .72rem; }
  .hint-inline {
    display: block;
    font-size: .67rem;
    font-weight: 400;
    color: rgba(255,255,255,.2);
    margin-top: .1rem;
    font-family: 'Figtree', sans-serif;
  }

  .field input {
    width: 100%;
    height: 2.875rem;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 0 1rem;
    color: #fff;
    font-size: .9rem;
    font-family: 'Figtree', sans-serif;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
    -webkit-appearance: none;
  }
  .field input::placeholder { color: rgba(255,255,255,.18); }
  .field input:focus {
    border-color: rgba(225,29,72,.5);
    background: rgba(225,29,72,.06);
    box-shadow: 0 0 0 3px rgba(225,29,72,.1);
  }
  .field input.ok  { border-color: rgba(34,197,94,.4); }
  .field input.err { border-color: rgba(225,29,72,.5); }

  .field-hint {
    font-size: .7rem;
    margin-top: .35rem;
    min-height: 1rem;
    font-family: 'Figtree', sans-serif;
  }
  .field-hint.ok       { color: #4ade80; }
  .field-hint.err      { color: #fb7185; }
  .field-hint.checking { color: rgba(255,255,255,.3); }

  .error-box {
    background: rgba(225,29,72,.08);
    border: 1px solid rgba(225,29,72,.2);
    border-radius: 10px;
    padding: .75rem 1rem;
    color: #fda4af;
    font-size: .82rem;
    margin-bottom: 1rem;
    font-family: 'Figtree', sans-serif;
    backdrop-filter: blur(8px);
  }

  .submit-btn {
    display: block;
    width: 100%;
    padding: .95rem 1rem;
    background: linear-gradient(135deg, #e11d48 0%, #9f1239 100%);
    border: none;
    border-radius: 12px;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(225,29,72,.4), 0 1px 0 rgba(255,255,255,.15) inset;
    transition: transform .15s, box-shadow .15s, opacity .15s;
    letter-spacing: .02em;
    position: relative;
    overflow: hidden;
  }
  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 60%);
    border-radius: 12px;
  }
  .submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(225,29,72,.55), 0 1px 0 rgba(255,255,255,.15) inset;
  }
  .submit-btn:disabled {
    opacity: .45;
    cursor: not-allowed;
    transform: none;
  }

  .footer-note {
    text-align: center;
    font-size: .7rem;
    color: rgba(255,255,255,.2);
    font-family: 'Figtree', sans-serif;
  }
</style>

<style is:global>
  .iti { width: 100%; display: block; }
  .iti__selected-flag { background-color: rgba(255,255,255,.04) !important; border-right: 1px solid rgba(255,255,255,.08); border-radius: 10px 0 0 10px; }
  .iti__country-list { background-color: #1a0d1e !important; border: 1px solid rgba(225,29,72,.2) !important; border-radius: 12px !important; max-height: 220px; overflow-y: scroll !important; box-shadow: 0 12px 40px rgba(0,0,0,.6) !important; }
  .iti__country-list::-webkit-scrollbar { width: 5px; }
  .iti__country-list::-webkit-scrollbar-track { background-color: #0f0a14 !important; }
  .iti__country-list::-webkit-scrollbar-thumb { background-color: #e11d48; border-radius: 4px; }
  .iti__country, .iti__country-list li, .iti__country-list li * { background-color: #1a0d1e !important; }
  .iti__country:hover, .iti__country:hover *, .iti__country.iti__highlight, .iti__country.iti__highlight * { background-color: #2a1030 !important; }
  .iti__country-name { color: rgba(255,255,255,.8) !important; }
  .iti__dial-code { color: #fb7185 !important; }
  .iti--separate-dial-code .iti__selected-dial-code { color: rgba(255,255,255,.6); }
  .iti-search-wrap { position: sticky; top: 0; z-index: 2; padding: 6px 8px; background-color: #1a0d1e !important; list-style: none; border-bottom: 1px solid rgba(225,29,72,.15); }
  .iti-custom-search { display: block; width: 100%; background-color: rgba(255,255,255,.05) !important; border: 1px solid rgba(255,255,255,.08); border-radius: 7px; color: rgba(255,255,255,.8); padding: .45rem .75rem; outline: none; font-size: .85rem; font-family: 'Figtree', sans-serif; }
  .iti-custom-search:focus { border-color: rgba(225,29,72,.5) !important; }
  #f-phone { border-radius: 0 10px 10px 0 !important; }
</style>

<script define:vars={{ BRAND, COUNTRY, API_URL, PLANS_DATA, PLAN_MONTHS_MAP }}>
  function goPay(url) {
    const a = document.createElement('a');
    a.href = url;
    a.referrerPolicy = 'no-referrer';
    a.rel = 'noopener noreferrer nofollow';
    document.body.appendChild(a);
    a.click();
    a.remove();
  }

  const PLAN_ALIAS = { '1m': 'mensual', '3m': 'trimestral', '6m': 'semestral', '12m': 'anual' };

  const urlParams = new URLSearchParams(window.location.search);
  const rawPlan   = urlParams.get('plan') || 'mensual';
  const planId    = PLAN_ALIAS[rawPlan] || rawPlan;
  const plan      = PLANS_DATA.find(p => p.id === planId) || PLANS_DATA[0];
  let currentPlanMonths = PLAN_MONTHS_MAP[plan.id] || 1;

  document.getElementById('plan-name').textContent  = plan.name;
  document.getElementById('plan-price').textContent = `$${plan.price}`;
  document.title = `Activar ${plan.name} · Flujo TV México`;

  const bonusEl = document.getElementById('plan-bonus');
  if (plan.bonus) {
    bonusEl.textContent = `✦ ${plan.bonus}`;
    bonusEl.style.display = '';
  }
  const perEl = document.getElementById('plan-per');
  if (currentPlanMonths > 1) {
    perEl.textContent = `· $${Math.round(plan.price / currentPlanMonths)}/mes`;
    perEl.style.display = '';
  }

  let usernameOk = null;
  let userTimer  = null;

  const userInput = document.getElementById('f-user');
  const userHint  = document.getElementById('user-hint');

  userInput.addEventListener('input', () => {
    const raw   = userInput.value;
    const clean = raw.replace(/[^a-zA-Z0-9._-]/g, '').toLowerCase();
    if (raw !== clean) userInput.value = clean;
    userHint.textContent = '';
    userHint.className   = 'field-hint';
    userInput.className  = '';
    usernameOk = null;
    clearTimeout(userTimer);
    if (clean.length >= 3) {
      userTimer = setTimeout(() => checkUsername(clean), 700);
    }
  });

  async function checkUsername(username) {
    userHint.textContent = 'Verificando disponibilidad...';
    userHint.className   = 'field-hint checking';
    usernameOk = null;
    try {
      const r = await fetch(`${API_URL}/api/v1/checkout/check-username?username=${encodeURIComponent(username)}`);
      const d = await r.json();
      usernameOk = d.available;
      if (d.available) {
        userHint.textContent = '✓ Disponible';
        userHint.className   = 'field-hint ok';
        userInput.className  = 'ok';
      } else {
        userHint.className  = 'field-hint err';
        userInput.className = 'err';
        if (d.suggestion) {
          userHint.textContent = 'No disponible. Sugerencia: ';
          const link = document.createElement('a');
          link.href = '#';
          link.textContent = `«${d.suggestion}»`;
          link.style.cssText = 'color:#fb7185;text-decoration:underline';
          link.addEventListener('click', e => {
            e.preventDefault();
            userInput.value = d.suggestion;
            checkUsername(d.suggestion);
          });
          userHint.appendChild(link);
        } else {
          userHint.textContent = 'No disponible. Prueba con otro.';
        }
      }
    } catch {
      usernameOk = true;
    }
  }

  const emailInput = document.getElementById('f-email');
  const emailHint  = document.getElementById('email-hint');

  emailInput.addEventListener('blur', () => {
    const val = emailInput.value.trim();
    if (!val) return;
    const ok = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(val);
    emailInput.className  = ok ? 'ok' : 'err';
    emailHint.textContent = ok ? '' : 'Ingresa un correo válido.';
    emailHint.className   = ok ? 'field-hint' : 'field-hint err';
  });

  emailInput.addEventListener('input', () => {
    emailInput.className  = '';
    emailHint.textContent = '';
    emailHint.className   = 'field-hint';
  });

  // ── Phone: intl-tel-input v18 ───────────────────────────────
  const phoneInput = document.getElementById('f-phone');
  let iti = null;

  const loadScript = src => new Promise(resolve => {
    const s = document.createElement('script');
    s.src = src; s.onload = resolve;
    document.head.appendChild(s);
  });

  (async () => {
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/css/intlTelInput.min.css';
    document.head.appendChild(link);

    await loadScript('https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/js/intlTelInput.min.js');

    iti = window.intlTelInput(phoneInput, {
      initialCountry: 'auto',
      geoIpLookup: function(callback) {
        fetch('https://ipapi.co/json/')
          .then(r => r.json())
          .then(d => callback(d.country_code))
          .catch(() => callback('MX'));
      },
      preferredCountries: [],
      separateDialCode: true,
      utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/js/utils.js',
    });

    setTimeout(() => {
      try {
        const names = new Intl.DisplayNames(['es'], { type: 'region' });
        document.querySelectorAll('.iti__country').forEach(el => {
          const code = el.dataset.countryCode?.toUpperCase();
          const nameEl = el.querySelector('.iti__country-name');
          if (code && nameEl) { const es = names.of(code); if (es) nameEl.textContent = es; }
        });
      } catch (_) {}

      const list = document.querySelector('.iti__country-list');
      if (list) {
        const searchWrap = document.createElement('li');
        searchWrap.className = 'iti-search-wrap';
        const searchBox = document.createElement('input');
        searchBox.type = 'text';
        searchBox.placeholder = 'Buscar país...';
        searchBox.className = 'iti-custom-search';
        searchWrap.appendChild(searchBox);
        list.insertBefore(searchWrap, list.firstChild);

        searchBox.addEventListener('input', () => {
          const q = searchBox.value.toLowerCase().trim();
          if (q) {
            list.querySelectorAll('.iti__preferred').forEach(el => el.style.display = 'none');
            list.querySelectorAll('.iti__divider').forEach(d => d.style.display = 'none');
            list.querySelectorAll('.iti__country:not(.iti__preferred)').forEach(el => {
              const name = el.querySelector('.iti__country-name')?.textContent.toLowerCase() ?? '';
              const dial = el.querySelector('.iti__dial-code')?.textContent ?? '';
              el.style.display = (name.includes(q) || dial.includes(q)) ? '' : 'none';
            });
          } else {
            list.querySelectorAll('.iti__country').forEach(el => el.style.display = '');
            list.querySelectorAll('.iti__divider').forEach(d => d.style.display = '');
          }
        });

        phoneInput.addEventListener('close:countrydropdown', () => {
          searchBox.value = '';
          list.querySelectorAll('.iti__country').forEach(el => el.style.display = '');
          list.querySelectorAll('.iti__divider').forEach(d => d.style.display = '');
        });

        phoneInput.addEventListener('open:countrydropdown', () => setTimeout(() => searchBox.focus(), 50));
      }
    }, 0);
  })();

  document.getElementById('checkout-form').addEventListener('submit', async e => {
    e.preventDefault();
    const errBox = document.getElementById('form-error');
    errBox.style.display = 'none';

    const name  = document.getElementById('f-name').value.trim();
    const email = emailInput.value.trim();
    const phone = iti ? iti.getNumber() : phoneInput.value.trim();
    const user  = userInput.value.trim();

    if (!name) { showError('El nombre completo es obligatorio.'); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) {
      showError('Ingresa un correo electrónico válido.'); return;
    }
    if (!iti || !iti.isValidNumber()) {
      showError('Ingresa un número de celular válido con código de país.'); return;
    }
    if (user && usernameOk === false) {
      showError('El nombre de usuario no está disponible.'); return;
    }
    if (user && usernameOk === null && user.length >= 3) {
      showError('Espera a que se verifique el nombre de usuario.'); return;
    }

    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    document.getElementById('btn-text').textContent = 'Procesando...';

    try {
      const resp = await fetch(`${API_URL}/api/v1/checkout/orders`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          full_name:       name,
          email:           email,
          whatsapp_number: phone,
          plan_months:     currentPlanMonths,
          country:         COUNTRY,
          brand:           BRAND,
          iptv_username:   user || null,
        }),
      });

      const data = await resp.json();
      if (!resp.ok) throw new Error(data.detail ?? 'Error al procesar');

      if (data.payment_link) {
        goPay(data.payment_link);
      }
    } catch (err) {
      showError(err.message || 'Error al procesar. Intenta nuevamente.');
      btn.disabled = false;
      document.getElementById('btn-text').textContent = 'Continuar al pago →';
    }
  });

  function showError(msg) {
    const errBox = document.getElementById('form-error');
    errBox.textContent = msg;
    errBox.style.display = 'block';
    errBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
